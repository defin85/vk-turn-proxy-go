{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vk-turn-proxy-go/test/compatibility/vk/fixture.schema.json",
  "title": "VK debug contour compatibility fixture",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "scenario_id",
    "provider",
    "input",
    "stages",
    "expected"
  ],
  "anyOf": [
    {
      "required": [
        "legacy_source"
      ]
    },
    {
      "required": [
        "browser_source"
      ]
    }
  ],
  "properties": {
    "scenario_id": {
      "type": "string",
      "pattern": "^vk_call_debug_[a-z0-9_]+_v[0-9]+$"
    },
    "provider": {
      "const": "vk"
    },
    "legacy_source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repo_path",
        "entrypoint",
        "function",
        "stage_count"
      ],
      "properties": {
        "repo_path": {
          "type": "string"
        },
        "entrypoint": {
          "type": "string"
        },
        "function": {
          "const": "getVkCreds"
        },
        "stage_count": {
          "const": 4
        }
      }
    },
    "browser_source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "captured_at",
        "contour"
      ],
      "properties": {
        "captured_at": {
          "type": "string",
          "format": "date"
        },
        "contour": {
          "type": "string",
          "enum": [
            "post_challenge_prejoin_preview",
            "post_challenge_post_preview"
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "invite_url_redacted",
        "normalized_join_token_redacted"
      ],
      "properties": {
        "invite_url_redacted": {
          "type": "string",
          "pattern": "^https://vk\\.com/call/join/<redacted:vk-join-token>$"
        },
        "normalized_join_token_redacted": {
          "type": "string",
          "pattern": "^<redacted:vk-join-token>$"
        }
      }
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "endpoint_id",
          "request",
          "response",
          "outcome"
        ],
        "properties": {
          "name": {
            "type": "string",
            "enum": [
              "vk_login_anonym_token",
              "vk_calls_get_anonymous_token",
              "vk_browser_login_anonym_token_messages",
              "vk_calls_get_call_preview",
              "ok_anonym_login",
              "ok_join_conversation_by_link"
            ]
          },
          "endpoint_id": {
            "type": "string",
            "enum": [
              "vk_login_anonym_token",
              "vk_calls_get_anonymous_token",
              "vk_browser_login_anonym_token_messages",
              "vk_calls_get_call_preview",
              "ok_anonym_login",
              "ok_join_conversation_by_link"
            ]
          },
          "request": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "method",
              "form_keys",
              "redacted_fields"
            ],
            "properties": {
              "method": {
                "const": "POST"
              },
              "form_keys": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "redacted_fields": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "response": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "status_code",
              "body"
            ],
            "properties": {
              "status_code": {
                "type": "integer",
                "minimum": 100,
                "maximum": 599
              },
              "body": {
                "type": "object"
              }
            }
          },
          "outcome": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "continue",
                  "resolution",
                  "provider_error"
                ]
              },
              "extracted": {
                "type": "object"
              },
              "error_code": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "expected": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "result_kind"
      ],
      "properties": {
        "result_kind": {
          "type": "string",
          "enum": [
            "resolution",
            "provider_error"
          ]
        },
        "resolution": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "username_redacted",
            "password_redacted",
            "address"
          ],
          "properties": {
            "username_redacted": {
              "type": "string",
              "pattern": "^<redacted:turn-username>$"
            },
            "password_redacted": {
              "type": "string",
              "pattern": "^<redacted:turn-password>$"
            },
            "address": {
              "type": "string",
              "pattern": "^[^?:]+:[0-9]+$"
            }
          }
        },
        "provider_error": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "stage",
            "code"
          ],
          "properties": {
            "stage": {
              "type": "string",
              "enum": [
                "vk_login_anonym_token",
                "vk_calls_get_anonymous_token",
                "vk_browser_login_anonym_token_messages",
                "vk_calls_get_call_preview",
                "ok_anonym_login",
                "ok_join_conversation_by_link"
              ]
            },
            "code": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
